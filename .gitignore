# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js build output ────────────────────────────────────────────────────
.next/
out/
build/

# ─── Environment variables ────────────────────────────────────────────────────
# Commit .env.example so teammates know which vars to set.
# Never commit real secrets.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Testing / coverage ───────────────────────────────────────────────────────
coverage/
.nyc_output/

# --- Local / machine-only (do not commit) ---
.claude/
**/settings.local.json

# ─── Debug logs ───────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ─── OS artefacts ─────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Certificates / secrets ───────────────────────────────────────────────────
*.pem
*.key
*.cert
*.p12

# ─── Deployment ───────────────────────────────────────────────────────────────
.vercel
.netlify

# ─── Misc ────────────────────────────────────────────────────────────────────
*.tgz
.cache/
tmp/
temp/
